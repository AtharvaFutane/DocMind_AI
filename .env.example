# AI Model Settings (supports OpenAI, Gemini, Ollama, etc.)
API_KEY=your-api-key-here
API_BASE_URL=
API_EMBEDDING_MODEL=text-embedding-3-small
API_CHAT_MODEL=gpt-4o
API_MAX_TOKENS=1000

# PostgreSQL
POSTGRES_USER=documind
POSTGRES_PASSWORD=documind_pass
POSTGRES_DB=documind_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# RAG Settings
CHUNK_SIZE=512
CHUNK_OVERLAP=128
TOP_K_RESULTS=5
FAISS_INDEX_PATH=./data/faiss_index

# Scraper Settings
SCRAPY_CONCURRENT_REQUESTS=8
SCRAPY_DOWNLOAD_DELAY=0.5
SCRAPY_DEPTH_LIMIT=10

# App
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=INFO
